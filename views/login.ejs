<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <title>Giriş Yap</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <div class="container auth-card" style="max-width:400px">
        <h2>Giriş Yap</h2>

        <% if(hata) { %>
            <p style="color:#e94560; margin-bottom:1rem; font-size:0.9rem">E-posta veya şifre hatalı.</p>
        <% } %>

        <form action="/login" method="post">

            <label for="email">E-posta:</label>
            <input type="email" id="email" name="email" required>

            <label for="password">Şifre:</label>
            <input type="password" id="password" name="password" required>

            <button type="submit" class="btn btn-primary">Giriş Yap</button>

        </form>

        <p style="margin-top:1rem">Hesabın yok mu? <a href="register">Kayıt Ol</a></p>
    </div>

</body>

</html>