<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Blog</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="container">
    <h1>Blog Yazıları</h1>
    <% if(posts.length === 0) { %>
        <p>Henüz yazı yok.</p>
    <% } else { %>
        <% posts.forEach(post => { %>
            <div class="post-card">
                <h2><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
                <p class="post-meta"><%= post.category %> — <%= post.createdAt.toLocaleDateString('tr-TR') %></p>
            </div>
        <% }) %>
    <% } %>
</div>
</body>
</html>
